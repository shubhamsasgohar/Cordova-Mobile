    </platform>
 
 
    <!-- ═══════════════════════════════════════════════════════════

         ANDROID PLATFORM CONFIGURATION

         Overrides global preferences for Android only

         ═══════════════════════════════════════════════════════════ -->
<platform name="android">

        <!-- Eliminates the 300ms tap delay on Android entirely -->
<preference name="FastClick" value="true" />
 
        <!-- Lock to portrait mode -->
<preference name="orientation" value="portrait" />

<preference name="DisallowOverscroll" value="true" />
 
        <!-- Keyboard settings - optimized for smooth behavior on Android -->
<preference name="KeyboardResize" value="true" />
<preference name="KeyboardResizeMode" value="body" />
<preference name="android-windowSoftInputMode" value="adjustResize" />
 
        <!-- Splash screen colors for Android 12+ splash screen API -->
<preference name="AndroidWindowSplashScreenBackground" value="#F5E9D3" />
<preference name="AndroidWindowSplashScreenAnimatedIcon" value="resources/icon.png" />
<preference name="AndroidWindowSplashScreenIconBackgroundColor" value="#F5E9D3" />
 
        <!-- Minimum Android API 22 = Android 5.1 (covers 99%+ devices) -->
<preference name="android-minSdkVersion" value="22" />
 
        <!-- Allow file:// URI access for local storage -->
<preference name="AndroidInsecureFileModeEnabled" value="true" />
 
        <!-- ── Android App Icons ───────────────────────────────── -->
<icon density="ldpi"    src="resources/android/icon/drawable-ldpi-icon.png"    />
<icon density="mdpi"    src="resources/android/icon/drawable-mdpi-icon.png"    />
<icon density="hdpi"    src="resources/android/icon/drawable-hdpi-icon.png"    />
<icon density="xhdpi"   src="resources/android/icon/drawable-xhdpi-icon.png"   />
<icon density="xxhdpi"  src="resources/android/icon/drawable-xxhdpi-icon.png"  />
<icon density="xxxhdpi" src="resources/android/icon/drawable-xxxhdpi-icon.png" />
 
        <!--

          CRITICAL — Allow HTTP (non-HTTPS) network requests on Android 9+

          Android blocks cleartext (http://) traffic by default since API 28

          Required for API calls to http:// backend server

          NOTE: For production / Play Store, migrate to HTTPS and remove this

        -->
<edit-config

            file="app/src/main/AndroidManifest.xml"

            mode="merge"

            target="/manifest/application">
<application android:usesCleartextTraffic="true" />
</edit-config>
 
    </platform>
 
</widget>
 