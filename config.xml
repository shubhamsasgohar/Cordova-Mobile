<?xml version='1.0' encoding='utf-8'?>
<!--

  HOW THIS FILE WORKS:

  - Global preferences apply to ALL platforms (iOS + Android)

  - Platform-specific blocks OVERRIDE global preferences

  - Order matters: platform block always wins over global

-->
 
<widget id="com.peaklyftdev.panditbooking"

        version="1.0.0"

        xmlns="http://www.w3.org/ns/widgets"

        xmlns:cdv="http://cordova.apache.org/ns/1.0"

        xmlns:android="http://schemas.android.com/apk/res/android">

<name>Smart Pujari</name>
<description>Smart Pujari by Peaklyft</description>
<author email="dev@peaklyft.com" href="https://peaklyft.com">

        Peaklyft
</author>
 
    <!-- Main entry point — loads index.html on app start -->
<content src="index.html" />
 
    <!-- ═══════════════════════════════════════════════════════════

         SECURITY — URL WHITELISTING

         Controls which URLs the app can navigate to or open

         Both http and https required for API calls to work

         ═══════════════════════════════════════════════════════════ -->
<allow-intent href="http://*/*" />
<allow-intent href="https://*/*" />
<allow-navigation href="http://*/*" />
<allow-navigation href="https://*/*" />
 
    <!-- Allow all origins for API calls (both http and https) -->
<access origin="*" />
 
    <!-- ═══════════════════════════════════════════════════════════

         GLOBAL PREFERENCES

         These apply to BOTH iOS and Android unless overridden

         in the platform-specific section below

         ═══════════════════════════════════════════════════════════ -->
 
    <!-- Disable back/forward swipe navigation (handled by React Router) -->
<preference name="AllowBackForwardNavigationGestures" value="false" />
 
    <!-- Disable pinch-to-zoom — app is not a website -->
<preference name="EnableViewportScale" value="false" />
 
    <!-- Disable overscroll bounce effect globally -->
<preference name="DisallowOverscroll" value="true" />
 
    <!-- Splash screen settings -->
<preference name="AutoHideSplashScreen" value="false" />
<preference name="SplashScreenDelay" value="0" />
<preference name="ShowSplashScreenSpinner" value="false" />
<preference name="FadeSplashScreen" value="true" />
 
    <!--

      VIEWPORT — viewport-fit=cover is REQUIRED for iOS safe area (notch/home bar)

      user-scalable=no prevents zoom on input focus

    -->
<preference name="Viewport" value="width=device-width, initial-scale=1, viewport-fit=cover, user-scalable=no" />
 
    <!-- Keyboard settings - optimized for cross-platform behavior -->
<preference name="HideKeyboardFormAccessoryBar" value="false" />
<preference name="KeyboardResize" value="true" />
<preference name="KeyboardResizeMode" value="body" />
 
    <!--

      CRITICAL FIX — Status bar must NOT overlay webview globally

      This prevents bottom nav from jumping on iOS

      iOS platform section below also sets this to false (redundant but safe)

    -->
<preference name="StatusBarOverlaysWebView" value="false" />
 
    <!-- App should not run in fullscreen — status bar must be visible -->
<preference name="Fullscreen" value="false" />
 
 
    <!-- ═══════════════════════════════════════════════════════════

         iOS PLATFORM CONFIGURATION

         Overrides global preferences for iPhone/iPad only

         ═══════════════════════════════════════════════════════════ -->
<platform name="ios">
 
        <!-- Lock to portrait mode -->
<preference name="orientation" value="portrait" />
 
        <!-- Disable swipe back — React Router handles navigation -->
<preference name="AllowBackForwardNavigationGestures" value="false" />
 
        <!-- Disable pinch zoom -->
<preference name="EnableViewportScale" value="false" />
 
        <!-- Disable bounce scroll on iOS -->
<preference name="DisallowOverscroll" value="true" />
<preference name="UIWebViewBounce" value="false" />
 
        <!-- Splash screen — 3 second delay with fade on iOS -->
<preference name="AutoHideSplashScreen" value="false" />
<preference name="SplashScreenDelay" value="3000" />
<preference name="FadeSplashScreen" value="true" />
<preference name="FadeSplashScreenDuration" value="1000" />
<preference name="ShowSplashScreenSpinner" value="false" />
 
        <!-- Use WKWebView only — UIWebView is deprecated by Apple -->
<preference name="WKWebViewOnly" value="true" />
<preference name="CordovaWebViewEngine" value="CDVWKWebViewEngine" />
 
        <!--

          CRITICAL FIX — Must be false on iOS

          When true: status bar overlaps app content → layout height miscalculates

          When false: status bar sits above app → correct safe area calculation

          This fixes the bottom nav jumping to top issue

        -->
<preference name="StatusBarOverlaysWebView" value="false" />
 
        <!-- App not fullscreen — status bar visible -->
<preference name="Fullscreen" value="false" />
 
        <!--

          Status bar appearance

          lightcontent = white text on status bar (good for dark/colored headers)

          BackgroundColor white matches app header

        -->
<preference name="StatusBarStyle" value="lightcontent" />
<preference name="StatusBarBackgroundColor" value="#ffffff" />
 
        <!-- Keyboard settings for iOS - optimized for smooth behavior -->
<preference name="HideKeyboardFormAccessoryBar" value="false" />
<preference name="KeyboardResize" value="true" />
<preference name="KeyboardResizeMode" value="body" />
 
        <!--

          Viewport with safe area support

          viewport-fit=cover enables env(safe-area-inset-*) CSS variables

          Required for notch and home indicator spacing

        -->
<preference name="Viewport" value="width=device-width, initial-scale=1, viewport-fit=cover" />

<preference name="DisallowOverscroll" value="true" />
 
        <!--

          PRIVACY PERMISSIONS

          Required strings shown to user when app requests device access

          Apple rejects apps without these descriptions

        -->
 
        <!-- Camera: used for profile photo capture -->
<edit-config file="*-Info.plist" mode="merge" target="NSCameraUsageDescription">
<string>Camera access for profile photo</string>
</edit-config>
 
        <!-- Photo Library Read: used to pick profile photo from gallery -->
<edit-config file="*-Info.plist" mode="merge" target="NSPhotoLibraryUsageDescription">
<string>Photo library access for profile photo</string>
</edit-config>
 
        <!-- Photo Library Write: used to save photos to device -->
<edit-config file="*-Info.plist" mode="merge" target="NSPhotoLibraryAddUsageDescription">
<string>Photo library access for saving photos</string>
</edit-config>
 
        <!--

          UIViewControllerBasedStatusBarAppearance = false

          Allows Cordova StatusBar plugin to control status bar appearance

          Without this, status bar color/style changes may not work on iOS

        -->
<edit-config file="*-Info.plist" mode="merge" target="UIViewControllerBasedStatusBarAppearance">
<false/>
</edit-config>
 
